# Tengu — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Anthropic API (required for autonomous agent mode) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Autonomous Agent Configuration ─────────────────────────────────────────────
# Used by autonomous_tengu.py and the docker compose agent profile
TENGU_AGENT_TARGET=juice-shop
TENGU_AGENT_SCOPE=172.20.0.0/24
TENGU_AGENT_TYPE=blackbox         # blackbox | greybox | whitebox
TENGU_AGENT_MAX_ITER=50

# ── Tengu MCP Server ────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
TENGU_LOG_LEVEL=INFO

# Path to the Tengu configuration file
TENGU_CONFIG_PATH=./tengu.toml

# NVD API Key (opcional — aumenta rate limit de 5 para 50 req/30s)
# Obtenha em: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# OWASP ZAP API Key (se usar ZAP)
ZAP_API_KEY=
ZAP_BASE_URL=http://localhost:8080

# Metasploit RPC
MSF_RPC_HOST=127.0.0.1
MSF_RPC_PORT=55553

# ── Docker ───────────────────────────────────────────────────────────────────
# Image tier: minimal (~400MB) | core (~2GB, default) | full (~3GB)
TENGU_TIER=core
# Host port for the MCP SSE server
TENGU_PORT=8000
# Comma-separated allowed scan targets (overrides docker/tengu.toml allowed_hosts)
TENGU_ALLOWED_HOSTS=
# Shodan API key (optional)
TENGU_SHODAN_API_KEY=

# Metasploit RPC password (profile: exploit)
MSF_RPC_PASSWORD=tengu

# ZAP API key (profile: proxy)
ZAP_API_KEY=tengu-zap-key
