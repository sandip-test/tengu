# Tengu — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores

# Nível de log: DEBUG, INFO, WARNING, ERROR
TENGU_LOG_LEVEL=INFO

# Caminho para o arquivo de configuração
TENGU_CONFIG_PATH=./tengu.toml

# NVD API Key (opcional — aumenta rate limit de 5 para 50 req/30s)
# Obtenha em: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# OWASP ZAP API Key (se usar ZAP)
ZAP_API_KEY=
ZAP_BASE_URL=http://localhost:8080

# Metasploit RPC
MSF_RPC_HOST=127.0.0.1
MSF_RPC_PORT=55553
MSF_RPC_PASSWORD=
MSF_RPC_SSL=true

# ── Docker ───────────────────────────────────────────────────────────────────
# Image tier: minimal (~400MB) | core (~2GB, default) | full (~3GB)
TENGU_TIER=core
# Host port for the MCP SSE server
TENGU_PORT=8000
# Comma-separated allowed scan targets (overrides docker/tengu.toml allowed_hosts)
TENGU_ALLOWED_HOSTS=
# Shodan API key (optional)
TENGU_SHODAN_API_KEY=

# Metasploit RPC password (profile: exploit)
MSF_RPC_PASSWORD=tengu

# ZAP API key (profile: proxy)
ZAP_API_KEY=tengu-zap-key
